#!/bin/bash

render_virtualenv() {
	if [[ -n "$VIRTUAL_ENV" ]]; then
		local glyph="¾░īĀ"
		local label=$(basename "$VIRTUAL_ENV")

		if $use_glyphs; then
			label="$glyph $label"
		fi

		if $use_badges; then
			make_badge "$label"
		else
			make_label "($label)"
		fi
	fi
}

render_identity() {
  local status=$?
  local glyph
  local label

  if is_error "$status"; then
		if $use_glyphs; then glyph="Ņ¬ć"; else glyph="!"; fi
	 	# Add blinking effect to error state glyph
		# glyph="\001\033[5m\002$glyph\001\033[25m\002"
		colour_global=$colour_error
  elif is_ssh; then
		if $use_glyphs; then glyph="¾░īś"; else glyph="*"; fi
  elif is_root; then
		if $use_glyphs; then glyph="ŅĘÅ"; else glyph="#"; fi
  else
		if $use_glyphs; then glyph="’Ćć"; else glyph="$"; fi
  fi

	if is_ssh || is_su; then
		label="$USER@$HOSTNAME"
	elif is_git; then
		label=$(get_git_project)
		glyph="¾░Ŗó"
	else
		label="$HOSTNAME"
	fi

	if $use_badges; then
		make_badge "$glyph $label"
	else
  	make_label "$glyph $label"
	fi
	
}

render_timestamps	() {
	local label="\T"
	local colour=$colour_neutral

	if $use_badges; then
        make_label "$label"
    else
        make_label "[$label]" "$colour_neutral"
    fi

}

render_path() {
	local glyph="’ü╗ "
	local label="\w"

	if $use_glyphs; then
		printf "%s %s" "$(make_label "$glyph ")" "$label"
	else
		printf "%s" "$label"
	fi
}

render_prompt() {
	local glyph

	if $use_glyphs && $use_badges; then glyph="¾▒×®"; else glyph="ŌåÆ"; fi
	if $use_badges; then glyph=" $glyph"; fi

	printf "\n%s" "$(make_label "$glyph")"
}

render_git() {
	local glyph="Ņ£ź"
	local label="%s"

	# Prevent if not a repository
	if ! is_git; then return 1; fi

	# Use brackets instead of badges
	if ! $use_badges; then
		label="($label)"
	fi

	# Prepend glyph to label
	if $use_glyphs; then
		label="$glyph $label"
	fi

	# Rendering logic
	if $use_badges; then
		format="$(make_badge "$label" "$colour_neutral")"
	elif $use_colours; then
		format="$(make_label "$label" "$colour_secondary")"
	else
		format="$label"
	fi

	# Safe git prompt
	if command -v __git_ps1 >/dev/null 2>&1; then
		__git_ps1 "$format"
	fi
}

make_label() {
  local content=$1
	local colour=${2:-$colour_global}

	## Prevent null content
	# if [[ -z $context ]]; then return 1; fi
	if $use_colours; then
		printf "\001\033[38;%sm\002" "$(hex_to_ansi "$colour")"
	fi

	printf "%b" "$content"

	if $use_colours; then
		## Reset foreground color
		printf "\001\033[0m\002"
	fi
}

make_badge() {
	local content=$1
	local colour=${2:-$colour_global}
	local glyph_left
	local glyph_right
	local ansi_sequence=38

 	if $use_glyphs; then
		## Use rounded corners
		glyph_left=$glyph_badge_left
		glyph_right=$glyph_badge_right
	else
		## Use basic padding
		content=" $content "
	fi

	if $use_colours; then
		## Set background and foreground sequence
		ansi_sequence=$(hex_to_ansi "$colour" true)
	else
		## Reverse video
		ansi_sequence=7
	fi

	printf "%s" "$(make_label "$glyph_left" "$colour")"
	printf "\001\033[%sm\002" "$ansi_sequence"
	printf "%b" "$content"
	printf "\001\033[0m\002"
	printf "%s" "$(make_label "$glyph_right" "$colour")"

}


## Helper functions
is_root() { [[ $EUID -eq 0 ]]; }

is_ssh() { [[ -n "$SSH_CLIENT" ]]; }

is_su() { [[ -n $LOGNAME && $USER != "$LOGNAME" ]]; }

is_error() { [[ $1 -ne 0 && $1 -ne 130 ]]; }

is_git() { [[ -n $(get_git_project) ]]; }

# Get top-level repository name
get_git_project() {
    # Skip execution if `git` is not available
    if ! command -v git > /dev/null 2>&1; then return 1; fi

    if git_root=$(git rev-parse --show-toplevel 2>/dev/null); then
        # Return the directory basename
        printf "%s" "${git_root##*/}"
    fi
}

hex_to_ansi() {
    local hex=$1
    local include_bg=${2:-false}

    local r=$((16#${hex:0:2}))
    local g=$((16#${hex:2:2}))
    local b=$((16#${hex:4:2}))

    ## Set truecolor bg while keeping default fg
    if $include_bg; then printf "30;48;"; fi

    printf "2;%s;%s;%s" "$r" "$g" "$b"
}


## Configuration
## Segments
declare -a segments=( virtualenv identity timestamps path git prompt )
declare -a dynamics=( virtualenv identity git )

## Define active features
declare use_colours=true
declare use_glyphs=true
declare use_badges=true

## Define custom colours
declare colour_primary="f5992e"
declare colour_secondary="785cea"
declare colour_neutral="5f5f87"
declare colour_error="f23a66"
declare colour_global

## Glyphs for borders
declare glyph_badge_left="ŅéČ"
declare glyph_badge_right="Ņé┤"

## Define main colour
if is_root; then
	colour_global=$colour_secondary
elif is_error; then
	colour_global=$colour_error
else
	colour_global=$colour_primary
fi


PS1=""
PS2="> " 
## For bash >v4
# PROMPT_DIRTRIM=2
export VIRTUAL_ENV_DISABLE_PROMPT=1
export GIT_PS1_SHOWSTASHSTATE=true
export GIT_PS1_SHOWDIRTYSTATE=true
export GIT_PS1_SHOWUNTRACKEDFILES=true
export GIT_PS1_SHOWUPSTREAM="git verbose"


for segment in "${segments[@]}"; do

	renderer="render_$segment"

	if [[ "${dynamics[*]}" =~ $segment ]]; then
		## Evaluate every time with command substitution
		PS1+="\$($renderer) "
	else
		## Evaluate only once
		PS1+="$($renderer) "
	fi

done

# Prepend blank line except after startup or clear
__print_blank() { [[ -n $__was_printed ]] && echo; __was_printed=1; }